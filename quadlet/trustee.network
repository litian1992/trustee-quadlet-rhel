# Trustee Network - Internal network for Trustee service communication
# This network connects KBS, AS, and RVPS containers

[Unit]
Description=Trustee Internal Network

[Network]
# Private network for inter-service communication
Subnet=10.89.0.0/24
Gateway=10.89.0.1

# Labels for identification
Label=app=trustee
Label=purpose=internal-communication

# DNS is enabled by default, allowing service discovery by container name
# e.g., trustee-rvps, trustee-as, trustee-kbs
